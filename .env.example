# PrintForge Environment Configuration
# Copy to .env and modify values

# Database
DATABASE_URL=postgresql://printforge:CHANGE_ME@db:5432/printforge
DB_PASSWORD=CHANGE_ME

# Auth
SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
JWT_EXPIRY=7d
COOKIE_SECURE=false

# Redis
REDIS_URL=redis://redis:6379

# App
NODE_ENV=production
API_PORT=4000
APP_PORT=3000

# Company defaults
COMPANY_NAME=My Print Farm
CURRENCY=OMR
TAX_RATE=0

# Costing
ELECTRICITY_RATE_KWH=0.025

# File uploads
UPLOAD_DIR=/app/uploads
WATCH_FOLDER=/app/uploads/watch

# Email (optional - for invoice sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Moonraker (comma-separated list of printer URLs, leave empty to disable)
MOONRAKER_URLS=
