generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ AUTH & USERS ============

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  role          Role     @default(OPERATOR)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  auditLogs            AuditLog[]
  assignedJobs         ProductionJob[]
  designAssignments    DesignProject[] @relation("DesignAssignments")
}

enum Role {
  ADMIN
  ACCOUNTING
  OPERATOR
  VIEWER
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId, createdAt])
}

// ============ CUSTOMERS ============

model Customer {
  id            String   @id @default(cuid())
  name          String
  email         String?  @unique
  phone         String?
  address       String?
  notes         String?
  portalAccess  Boolean  @default(false)
  passwordHash  String?
  isApproved    Boolean  @default(false)
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  refreshToken  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders         Order[]
  quotes         Quote[]
  designProjects DesignProject[]
}

// ============ INVENTORY ============

model Material {
  id              String       @id @default(cuid())
  name            String
  type            MaterialType
  color           String?
  brand           String?
  costPerGram     Float
  density         Float        @default(1.24)
  reorderPoint    Float        @default(500)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  spools              Spool[]
  jobMaterials        JobMaterial[]
  productComponents   ProductComponent[]
  componentMaterials  ComponentMaterial[]
}

enum MaterialType {
  PLA
  PETG
  ABS
  TPU
  ASA
  NYLON
  RESIN
  OTHER
}

model StorageLocation {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  spools      Spool[]
}

model Spool {
  id              String           @id @default(cuid())
  printforgeId    String?          @unique
  materialId      String
  material        Material         @relation(fields: [materialId], references: [id])
  initialWeight   Float
  currentWeight   Float
  spoolWeight     Float            @default(200)
  lotNumber       String?
  purchasePrice   Float?
  purchaseDate    DateTime?
  locationId      String?
  location        StorageLocation? @relation(fields: [locationId], references: [id])
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  jobMaterials    JobMaterial[]

  @@index([materialId])
  @@index([isActive])
}

// ============ PRODUCTS (BOM) ============

model Product {
  id                String   @id @default(cuid())
  name              String
  description       String?
  sku               String?  @unique
  estimatedMinutes  Float    @default(0)
  estimatedGrams    Float    @default(0)
  colorChanges      Int      @default(0)
  basePrice         Float    @default(0)
  imageUrl          String?
  isActive          Boolean  @default(true)
  defaultPrinterId  String?
  defaultPrinter    Printer? @relation(fields: [defaultPrinterId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  variants          ProductVariant[]
  components        ProductComponent[]
  productionJobs    ProductionJob[]
}

model ProductVariant {
  id               String   @id @default(cuid())
  productId        String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name             String
  sku              String?  @unique
  basePrice        Float?
  estimatedMinutes Float?
  estimatedGrams   Float?
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  orderItems       OrderItem[]
  productionJobs   ProductionJob[]

  @@index([productId])
}

model ProductComponent {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  materialId      String?
  material        Material? @relation(fields: [materialId], references: [id])
  description     String
  gramsUsed       Float
  printMinutes    Float    @default(0)
  quantity        Int      @default(1)
  sortOrder       Int      @default(0)
  stockOnHand     Int      @default(0)
  isMultiColor    Boolean  @default(false)
  createdAt       DateTime @default(now())

  materials       ComponentMaterial[]
  productionJobs  ProductionJob[]
}

model ComponentMaterial {
  id              String           @id @default(cuid())
  componentId     String
  component       ProductComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  materialId      String
  material        Material         @relation(fields: [materialId], references: [id])
  gramsUsed       Float
  colorIndex      Int              @default(0)
  sortOrder       Int              @default(0)

  @@unique([componentId, colorIndex])
}

// ============ PRINTERS ============

model Printer {
  id              String              @id @default(cuid())
  name            String
  model           String?
  connectionType  PrinterConnectionType
  moonrakerUrl    String?
  cameraUrl       String?             // MJPEG stream URL (e.g. http://192.168.x.x:8000)
  hourlyRate      Float               @default(0.40)
  wattage         Float               @default(200)
  markupMultiplier Float              @default(2.5)
  isActive        Boolean             @default(true)
  status          PrinterStatus       @default(OFFLINE)
  lastSeen        DateTime?

  // Maintenance tracking
  totalPrintHours            Float    @default(0)
  maintenanceIntervalHours   Float?
  nextMaintenanceDue         DateTime? // kept for calendar-based reminders; overdue uses print-hour delta
  lastMaintenancePrintHours  Float    @default(0) // totalPrintHours at time of last completed maintenance

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  productionJobs  ProductionJob[]
  defaultProducts Product[]
  maintenanceLogs MaintenanceLog[]

  @@index([connectionType, isActive])
}

model MaintenanceLog {
  id              String              @id @default(cuid())
  printerId       String
  printer         Printer             @relation(fields: [printerId], references: [id], onDelete: Cascade)
  type            MaintenanceType
  description     String
  scheduledDate   DateTime?
  completedDate   DateTime?
  downtimeMinutes Int?
  cost            Float?
  performedById   String?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([printerId])
}

enum MaintenanceType {
  SCHEDULED
  UNSCHEDULED
  CALIBRATION
}

enum PrinterConnectionType {
  MOONRAKER
  CREALITY_WS
  CREALITY_CLOUD
  MANUAL
}

enum PrinterStatus {
  IDLE
  PRINTING
  PAUSED
  ERROR
  OFFLINE
  MAINTENANCE
}

// ============ PRODUCTION ============

model ProductionJob {
  id              String     @id @default(cuid())
  name            String
  status          JobStatus  @default(QUEUED)
  printerId       String?
  printer         Printer?   @relation(fields: [printerId], references: [id])
  assignedToId    String?
  assignedTo      User?      @relation(fields: [assignedToId], references: [id])
  orderId         String?
  order           Order?     @relation(fields: [orderId], references: [id])
  orderItemId     String?
  orderItem       OrderItem? @relation(fields: [orderItemId], references: [id])
  productId       String?
  product         Product?   @relation(fields: [productId], references: [id])
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  componentId     String?
  component       ProductComponent? @relation(fields: [componentId], references: [id])
  quantityToProduce Int      @default(1)

  printDuration   Float?
  filamentUsedMm  Float?

  colorChanges    Int        @default(0)
  purgeWasteGrams Float      @default(0)

  materialCost    Float?
  machineCost     Float?
  wasteCost       Float?
  overheadCost    Float?
  totalCost       Float?

  moonrakerJobId  String?
  gcodeFilename   String?

  // Failed print tracking
  failureReason   String?
  failedAt        DateTime?
  wasteGrams      Float      @default(0)
  reprintOfId     String?
  reprintOf       ProductionJob?  @relation("Reprints", fields: [reprintOfId], references: [id])
  reprints        ProductionJob[] @relation("Reprints")

  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  materials       JobMaterial[]
  attachments     Attachment[]

  @@index([status])
  @@index([orderId])
  @@index([reprintOfId])
  @@index([printerId])
  @@index([printerId, status])
  @@index([completedAt])
}

enum JobStatus {
  QUEUED
  IN_PROGRESS
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

model JobMaterial {
  id              String        @id @default(cuid())
  jobId           String
  job             ProductionJob @relation(fields: [jobId], references: [id])
  materialId      String
  material        Material      @relation(fields: [materialId], references: [id])
  spoolId         String?
  spool           Spool?        @relation(fields: [spoolId], references: [id])
  gramsUsed       Float
  costPerGram     Float
  colorIndex      Int           @default(0)
  createdAt       DateTime      @default(now())
}

// ============ ORDERS ============

model Quote {
  id              String       @id @default(cuid())
  quoteNumber     String       @unique
  customerId      String
  customer        Customer     @relation(fields: [customerId], references: [id])
  status          QuoteStatus  @default(DRAFT)
  source          QuoteSource  @default(MANUAL)
  subtotal        Float        @default(0)
  tax             Float        @default(0)
  total           Float        @default(0)
  notes           String?
  validUntil      DateTime?
  gcodeMetadata   Json?
  stlMetadata     Json?
  costBreakdown   Json?
  createdById     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  items           QuoteItem[]
  order           Order?
  attachments     Attachment[]
  designProject   DesignProject?

  @@index([status])
  @@index([customerId])
}

enum QuoteSource {
  MANUAL
  QUICK_QUOTE
  CUSTOMER
  DESIGN
  LINK
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model QuoteItem {
  id                 String   @id @default(cuid())
  quoteId            String
  quote              Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId          String?
  description        String
  quantity           Int      @default(1)
  unitPrice          Float
  totalPrice         Float
  estimatedGrams     Float?
  estimatedMinutes   Float?
  estimatedColors    Int?
  estimatedCost      Float?
  marginPercent      Float?
  createdAt          DateTime @default(now())

  @@index([quoteId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id])
  quoteId         String?     @unique
  quote           Quote?      @relation(fields: [quoteId], references: [id])
  status          OrderStatus @default(PENDING)
  subtotal        Float       @default(0)
  tax             Float       @default(0)
  total           Float       @default(0)
  paidAmount      Float       @default(0)
  notes           String?
  dueDate         DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           OrderItem[]
  productionJobs  ProductionJob[]
  invoices        Invoice[]
  attachments     Attachment[]

  @@index([status])
  @@index([customerId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  READY
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String?
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  description     String
  quantity        Int             @default(1)
  unitPrice       Float
  totalPrice      Float
  materialCost    Float?
  createdAt       DateTime        @default(now())

  productionJobs  ProductionJob[]

  @@index([orderId])
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])
  status          InvoiceStatus @default(DRAFT)
  subtotal        Float
  tax             Float
  total           Float
  paidAmount      Float         @default(0)
  issuedAt        DateTime?
  dueDate         DateTime?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  attachments     Attachment[]

  @@index([paidAt])
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

// ============ ACCOUNTING ============

model ExpenseCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())

  expenses    Expense[]
}

model Expense {
  id           String          @id @default(cuid())
  categoryId   String
  category     ExpenseCategory @relation(fields: [categoryId], references: [id])
  description  String
  amount       Float
  date         DateTime
  recurring    Boolean         @default(false)
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([categoryId])
  @@index([date])
}

// ============ FILE MANAGEMENT ============

model Attachment {
  id              String   @id @default(cuid())
  filename        String
  originalName    String
  mimeType        String
  sizeBytes       Int
  storagePath     String
  entityType      String
  entityId        String
  parsedMetadata  Json?
  uploadedById    String?
  createdAt       DateTime @default(now())

  // Polymorphic relation — entityType + entityId reference different tables
  // (Quote, Order, ProductionJob, DesignProject, Invoice) without FK constraints
  quoteId         String?
  quote           Quote?         @relation(fields: [quoteId], references: [id])
  orderId         String?
  order           Order?         @relation(fields: [orderId], references: [id])
  jobId           String?
  productionJob   ProductionJob? @relation(fields: [jobId], references: [id])
  designProjectId String?
  designProject   DesignProject? @relation(fields: [designProjectId], references: [id])
  invoiceId       String?
  invoice         Invoice?       @relation(fields: [invoiceId], references: [id])

  @@index([entityType, entityId])
}

// ============ DESIGN MODULE (groundwork) ============

model DesignProject {
  id                String       @id @default(cuid())
  projectNumber     String       @unique
  customerId        String
  customer          Customer     @relation(fields: [customerId], references: [id])
  assignedToId      String?
  assignedTo        User?        @relation("DesignAssignments", fields: [assignedToId], references: [id])
  status            DesignStatus @default(REQUESTED)
  title             String
  brief             String?
  budget            Float?
  quotedPrice       Float?
  designFeeType     DesignFeeType @default(FLAT)
  designFeeAmount   Float?
  designFeeHours    Float?
  totalDesignFee    Float?
  estimatedDelivery DateTime?
  quoteId           String?      @unique
  quote             Quote?       @relation(fields: [quoteId], references: [id])
  deadline          DateTime?
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  revisions         DesignRevision[]
  comments          DesignComment[]
  attachments       Attachment[]

  @@index([status])
  @@index([customerId])
  @@index([assignedToId])
}

enum DesignFeeType {
  FLAT
  HOURLY
}

enum DesignStatus {
  REQUESTED
  ASSIGNED
  IN_PROGRESS
  REVIEW
  REVISION
  APPROVED
  QUOTED
  IN_PRODUCTION
  COMPLETED
  CANCELLED
}

model DesignRevision {
  id              String        @id @default(cuid())
  projectId       String
  project         DesignProject @relation(fields: [projectId], references: [id])
  versionNumber   Int
  description     String?
  internalNotes   String?
  customerNotes   String?
  createdAt       DateTime      @default(now())

  comments        DesignComment[]
}

model DesignComment {
  id              String          @id @default(cuid())
  projectId       String
  project         DesignProject   @relation(fields: [projectId], references: [id])
  revisionId      String?
  revision        DesignRevision? @relation(fields: [revisionId], references: [id])
  authorId        String?
  authorName      String
  isCustomer      Boolean         @default(false)
  content         String
  attachmentIds   String[]
  createdAt       DateTime        @default(now())
}

// ============ SYSTEM ============

model SystemSetting {
  id      String @id @default(cuid())
  key     String @unique
  value   String
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  title       String
  message     String
  entityType  String?
  entityId    String?
  isRead      Boolean          @default(false)
  userId      String?
  createdAt   DateTime         @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

enum NotificationType {
  LOW_STOCK
  ORDER_CREATED
  ORDER_STATUS_CHANGED
  JOB_COMPLETED
  JOB_FAILED
  INVOICE_OVERDUE
  DESIGN_REVISION_UPLOADED
  DESIGN_APPROVED
  DESIGN_CHANGES_REQUESTED
  MAINTENANCE_DUE
  SYSTEM
}
